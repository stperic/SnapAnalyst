# Database Configuration
DATABASE_URL=postgresql://snapanalyst:snapanalyst_dev_password@localhost:5432/snapanalyst_db

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# Data Path
SNAPDATA_PATH=./datasets/snap/data

# Security
SECRET_KEY=dev-secret-key-change-in-production

# Provider: openai | anthropic | ollama
LLM_PROVIDER=openai

# =============================================================================
# API KEYS (required based on provider)
# =============================================================================
# OpenAI
# OPENAI_API_KEY=sk-proj-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# SQL Generation (LLM_SQL_*)
LLM_SQL_MODEL=gpt-4-turbo-preview
LLM_SQL_MAX_TOKENS=2000
LLM_SQL_TEMPERATURE=0.1

# Summary Generation (LLM_SUMMARY_*)
LLM_SUMMARY_MODEL=gpt-3.5-turbo
LLM_SUMMARY_MAX_TOKENS=200
LLM_SUMMARY_MAX_PROMPT_SIZE=8000
LLM_SUMMARY_TEMPERATURE=0.3

# Vanna/Training (currently disabled for performance)
# VANNA_TRAINING_ENABLED=false

# Log rotation settings
LOG_MAX_BYTES=10000000
LOG_BACKUP_COUNT=5