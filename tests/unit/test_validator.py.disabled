"""
Unit tests for DataValidator
"""
from decimal import Decimal

import pytest

from src.etl.validator import DataValidator, ValidationResult


class TestValidationResult:
    """Test ValidationResult class"""
    
    def test_init(self):
        """Test ValidationResult initialization"""
        result = ValidationResult()
        
        assert result.errors == []
        assert result.warnings == []
        assert result.info == []
        assert result.is_valid is True
        assert result.has_warnings is False
    
    def test_add_error(self):
        """Test adding validation error"""
        result = ValidationResult()
        result.add_error("Test error")
        
        assert len(result.errors) == 1
        assert result.errors[0] == "Test error"
        assert result.is_valid is False
    
    def test_add_warning(self):
        """Test adding validation warning"""
        result = ValidationResult()
        result.add_warning("Test warning")
        
        assert len(result.warnings) == 1
        assert result.warnings[0] == "Test warning"
        assert result.has_warnings is True
        assert result.is_valid is True  # Warnings don't affect validity


class TestDataValidator:
    """Test suite for DataValidator class"""
    
    def test_init(self):
        """Test DataValidator initialization"""
        validator = DataValidator(strict=True)
        assert validator.strict is True
        
        validator = DataValidator(strict=False)
        assert validator.strict is False
    
    def test_validate_household_valid(self, sample_household_data: dict):
        """Test validating a valid household"""
        validator = DataValidator()
        result = validator.validate_household(sample_household_data)
        
        assert result.is_valid
        assert len(result.errors) == 0
    
    def test_validate_household_missing_case_id(self, sample_household_data: dict):
        """Test validation fails when case_id is missing"""
        validator = DataValidator()
        data = sample_household_data.copy()
        del data["case_id"]
        
        result = validator.validate_household(data)
        
        assert not result.is_valid
        assert any("case_id" in error for error in result.errors)
    
    def test_validate_household_negative_benefit(self, sample_household_data: dict):
        """Test validation fails with negative SNAP benefit"""
        validator = DataValidator()
        data = sample_household_data.copy()
        data["snap_benefit"] = Decimal("-100.00")
        
        result = validator.validate_household(data)
        
        assert not result.is_valid
        assert any("Negative SNAP benefit" in error for error in result.errors)
    
    def test_validate_household_invalid_size(self, sample_household_data: dict):
        """Test validation fails with invalid household size"""
        validator = DataValidator()
        data = sample_household_data.copy()
        data["certified_household_size"] = 0
        
        result = validator.validate_household(data)
        
        assert not result.is_valid
        assert any("Invalid household size" in error for error in result.errors)
    
    def test_validate_household_gross_less_than_net(self, sample_household_data: dict):
        """Test validation fails when gross < net income"""
        validator = DataValidator()
        data = sample_household_data.copy()
        data["gross_income"] = Decimal("1000.00")
        data["net_income"] = Decimal("2000.00")
        
        result = validator.validate_household(data)
        
        assert not result.is_valid
        assert any("Gross income" in error and "net income" in error for error in result.errors)
    
    def test_validate_member_valid(self, sample_member_data: dict):
        """Test validating a valid member"""
        validator = DataValidator()
        result = validator.validate_member(sample_member_data)
        
        assert result.is_valid
        assert len(result.errors) == 0
    
    def test_validate_member_invalid_age(self, sample_member_data: dict):
        """Test validation fails with invalid age"""
        validator = DataValidator()
        data = sample_member_data.copy()
        data["age"] = 150  # Too old
        
        result = validator.validate_member(data)
        
        assert not result.is_valid
        assert any("Invalid age" in error for error in result.errors)
    
    def test_validate_member_negative_age(self, sample_member_data: dict):
        """Test validation fails with negative age"""
        validator = DataValidator()
        data = sample_member_data.copy()
        data["age"] = -5
        
        result = validator.validate_member(data)
        
        assert not result.is_valid
    
    def test_validate_member_invalid_number(self, sample_member_data: dict):
        """Test validation fails with invalid member number"""
        validator = DataValidator()
        data = sample_member_data.copy()
        data["member_number"] = 18  # Max is 17
        
        result = validator.validate_member(data)
        
        assert not result.is_valid
        assert any("member_number" in error for error in result.errors)
    
    def test_validate_member_negative_wages(self, sample_member_data: dict):
        """Test validation fails with negative wages"""
        validator = DataValidator()
        data = sample_member_data.copy()
        data["wages"] = Decimal("-1000.00")
        
        result = validator.validate_member(data)
        
        assert not result.is_valid
        assert any("Negative wages" in error for error in result.errors)
    
    def test_validate_error_valid(self, sample_error_data: dict):
        """Test validating a valid error"""
        validator = DataValidator()
        result = validator.validate_error(sample_error_data)
        
        assert result.is_valid
        assert len(result.errors) == 0
    
    def test_validate_error_invalid_number(self, sample_error_data: dict):
        """Test validation fails with invalid error number"""
        validator = DataValidator()
        data = sample_error_data.copy()
        data["error_number"] = 10  # Max is 9
        
        result = validator.validate_error(data)
        
        assert not result.is_valid
        assert any("error_number" in error for error in result.errors)
    
    def test_validate_error_very_large_amount(self, sample_error_data: dict):
        """Test validation warns with very large error amount"""
        validator = DataValidator()
        data = sample_error_data.copy()
        data["error_amount"] = Decimal("200000.00")
        
        result = validator.validate_error(data)
        
        # Should pass but with warning
        assert result.is_valid
        assert result.has_warnings
        assert any("large error amount" in warning for warning in result.warnings)
    
    def test_validate_batch_all_valid(
        self,
        sample_household_data: dict,
        sample_member_data: dict,
        sample_error_data: dict
    ):
        """Test batch validation with all valid data"""
        validator = DataValidator()
        
        households = [sample_household_data]
        members = [sample_member_data]
        errors = [sample_error_data]
        
        result = validator.validate_batch(households, members, errors)
        
        assert result.is_valid
    
    def test_validate_batch_with_errors(self, sample_household_data: dict):
        """Test batch validation catches errors"""
        validator = DataValidator()
        
        # Create invalid household
        bad_household = sample_household_data.copy()
        bad_household["snap_benefit"] = Decimal("-100.00")
        
        households = [sample_household_data, bad_household]
        
        result = validator.validate_batch(households, [], [])
        
        assert not result.is_valid
        assert len(result.errors) > 0
