"""
Unit tests for CSVReader
"""
from pathlib import Path

import polars as pl
import pytest

from src.core.exceptions import FileNotFoundError, ValidationError
from src.etl.reader import CSVReader


class TestCSVReader:
    """Test suite for CSVReader class"""
    
    def test_init_with_valid_file(self, test_csv_path: Path):
        """Test CSVReader initialization with valid file"""
        reader = CSVReader(str(test_csv_path))
        
        assert reader.file_path == test_csv_path
        assert reader.file_size_bytes > 0
    
    def test_init_with_invalid_file(self):
        """Test CSVReader initialization with non-existent file"""
        with pytest.raises(FileNotFoundError):
            CSVReader("/nonexistent/file.csv")
    
    def test_read_csv_basic(self, small_csv_path: Path):
        """Test basic CSV reading"""
        reader = CSVReader(str(small_csv_path))
        df = reader.read_csv()
        
        assert isinstance(df, pl.DataFrame)
        assert len(df) > 0
        assert len(df.columns) > 0
    
    def test_read_csv_with_limit(self, test_csv_path: Path):
        """Test reading limited number of rows"""
        reader = CSVReader(str(test_csv_path))
        df = reader.read_csv(n_rows=5)
        
        assert len(df) == 5
    
    def test_read_csv_with_skip(self, test_csv_path: Path):
        """Test reading with skipped rows"""
        reader = CSVReader(str(test_csv_path))
        df_full = reader.read_csv(n_rows=10)
        df_skip = reader.read_csv(skip_rows=5, n_rows=5)
        
        # Should have read rows 6-10
        assert len(df_skip) == 5
    
    def test_get_row_count(self, test_csv_path: Path):
        """Test getting row count"""
        reader = CSVReader(str(test_csv_path))
        row_count = reader.get_row_count()
        
        assert row_count > 0
        assert isinstance(row_count, int)
    
    def test_get_column_names(self, test_csv_path: Path):
        """Test getting column names"""
        reader = CSVReader(str(test_csv_path))
        columns = reader.get_column_names()
        
        assert isinstance(columns, list)
        assert len(columns) > 0
        # Check for expected columns
        assert "CASE" in columns
        assert "STATE" in columns
        assert "FSBEN" in columns
    
    def test_validate_structure_success(self, test_csv_path: Path):
        """Test CSV structure validation with valid file"""
        reader = CSVReader(str(test_csv_path))
        df = reader.read_csv(n_rows=1)
        
        # Should not raise exception
        reader._validate_structure(df)
    
    def test_validate_structure_missing_columns(self, tmp_path: Path):
        """Test CSV structure validation with missing columns"""
        # Create invalid CSV without required columns
        invalid_csv = tmp_path / "invalid.csv"
        invalid_csv.write_text("COL1,COL2\n1,2\n")
        
        reader = CSVReader(str(invalid_csv))
        
        with pytest.raises(ValidationError, match="Missing required columns"):
            reader.read_csv()
    
    def test_read_in_chunks(self, test_csv_path: Path):
        """Test reading CSV in chunks"""
        reader = CSVReader(str(test_csv_path))
        chunks = list(reader.read_in_chunks(chunk_size=1000))
        
        assert len(chunks) > 0
        assert all(isinstance(chunk, pl.DataFrame) for chunk in chunks)
        assert all(len(chunk) <= 1000 for chunk in chunks)
    
    def test_file_size_tracking(self, test_csv_path: Path):
        """Test file size is tracked correctly"""
        reader = CSVReader(str(test_csv_path))
        
        assert reader.file_size_bytes > 0
        # Test CSV should be several MB
        assert reader.file_size_bytes > 1_000_000  # > 1MB
