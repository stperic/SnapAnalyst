                    "range": "200112-999999",
                    "example": 202210,
                    "source_field": "OCCDATEi",
                    "codes": {
                        "999999": "Unknown"
                    }
                },
                "time_period": {
                    "type": "VARCHAR(20)",
                    "description": "Variance time period",
                    "nullable": true,
                    "range": "1-9",
                    "example": "3",
                    "source_field": "TIMEPERi",
                    "codes": {
                        "1": "Before most recent action",
                        "2": "At time of most recent action",
                        "3": "After most recent action",
                        "9": "Cannot be determined"
                    }
                },
                "error_finding": {
                    "type": "INTEGER",
                    "description": "Impact of variance on benefits",
                    "nullable": true,
                    "range": "2-4",
                    "example": 3,
                    "source_field": "E_FINDGi",
                    "codes": {
                        "2": "Overissuance",
                        "3": "Underissuance",
                        "4": "Ineligible"
                    }
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "description": "Record creation timestamp",
                    "nullable": false,
                    "source_field": "Auto-generated by database",
                    "notes": "Not in source CSV - database audit field"
                }
            }
        }
    },
    "relationships": {
        "households_to_members": {
            "type": "ONE_TO_MANY",
            "description": "One household has 1-17 members",
            "join": "households.case_id = household_members.case_id AND households.fiscal_year = household_members.fiscal_year"
        },
        "households_to_errors": {
            "type": "ONE_TO_MANY",
            "description": "One household has 0-9 QC errors",
            "join": "households.case_id = qc_errors.case_id AND households.fiscal_year = qc_errors.fiscal_year"
        }
    }
}