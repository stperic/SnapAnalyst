                },
                "member_number": {
                    "type": "INTEGER",
                    "description": "Member position in household (1-17, part of composite primary key)",
                    "nullable": false,
                    "range": "1-17",
                    "example": 1,
                    "source_field": "Derived from column suffix (AGE1→1, AGE2→2, etc.)",
                    "notes": "Extracted from the 'i' in source field names like AGEi, WAGESi"
                },
                "age": {
                    "type": "INTEGER",
                    "description": "Age in years",
                    "nullable": true,
                    "range": "0-98",
                    "example": 62,
                    "source_field": "AGEi",
                    "codes": {
                        "0": "Age less than 1 year",
