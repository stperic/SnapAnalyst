                        "3": "Prefer not to answer"
                    }
                },
                "snap_affiliation_code": {
                    "type": "INTEGER",
                    "description": "SNAP case affiliation - member's participation status",
                    "nullable": true,
                    "range": "1-99",
                    "source_field": "FSAFILi",
                    "codes": {
                        "1": "Eligible member entitled to receive benefits",
                        "2": "Eligible participant in another unit",
                        "4": "Ineligible noncitizen (not in State-funded SNAP)",
                        "7": "Ineligible student",
                        "8": "Disqualified for program violation",
                        "9": "Ineligible due to work requirement failure",
                        "19": "Individual in home but not part of SNAP household",
                        "99": "Unknown"
                    }
                },
                "disability_indicator": {
                    "type": "INTEGER",
                    "description": "Person-level disability indicator",
                    "nullable": true,
                    "range": "0-1",
