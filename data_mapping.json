                    "codes": {
                        "0": "Not disabled",
                        "1": "Disabled"
                    }
                },
                "foster_child_indicator": {
                    "type": "INTEGER",
                    "description": "Foster child status",
                    "nullable": true,
                    "source_field": "FOSTERi",
                    "notes": "Coded value from source data"
                },
                "working_indicator": {
                    "type": "INTEGER",
                    "description": "Person-level working indicator",
                    "nullable": true,
                    "range": "0-1",
                    "source_field": "WORKi",
                    "codes": {
                        "0": "No",
                        "1": "Yes"
                    }
                },
                "wages": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable wages and salaries",
                    "nullable": false,
                    "range": "0-7526",
                    "example": 0.00,
                    "source_field": "WAGESi"
                },
                "self_employment_income": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable self-employment income",
                    "nullable": false,
                    "range": "0-5210",
                    "example": 0.00,
                    "source_field": "SLFEMPi"
                },
                "social_security": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable Social Security income (RSDI)",
                    "nullable": false,
                    "range": "0-6800",
                    "example": 561.00,
                    "source_field": "SOCSECi"
                },
                "ssi": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable SSI benefits",
                    "nullable": false,
                    "range": "0-2406",
                    "example": 0.00,
                    "source_field": "SSIi"
                },
                "unemployment": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable unemployment compensation",
                    "nullable": false,
                    "range": "0-3254",
                    "example": 0.00,
                    "source_field": "UNEMPi"
                },
                "tanf": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable TANF payments",
                    "nullable": false,
                    "range": "0-2185",
                    "example": 0.00,
                    "source_field": "TANFi"
                },
                "child_support": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable child support payment income",
                    "nullable": false,
                    "range": "0-2561",
                    "example": 0.00,
                    "source_field": "CSUPRTi"
                },
                "veterans_benefits": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable veterans' benefits",
                    "nullable": false,
                    "range": "0-4273",
                    "example": 0.00,
                    "source_field": "VETi"
                },
                "workers_compensation": {
                    "type": "DECIMAL(10,2)",
                    "description": "Countable workers' compensation benefits",
                    "nullable": false,
                    "range": "0-4441",
                    "example": 0.00,
                    "source_field": "WCOMPi"
                },
                "total_earned_income": {
                    "type": "DECIMAL(10,2)",
                    "description": "Sum of all earned income sources (calculated field)",
                    "nullable": true,
                    "source_field": "Calculated: wages + self_employment_income + other_earned",
                    "notes": "Not in source CSV - computed from member income fields"
                },
                "total_unearned_income": {
                    "type": "DECIMAL(10,2)",
                    "description": "Sum of all unearned income sources (calculated field)",
                    "nullable": true,
                    "source_field": "Calculated: social_security + ssi + unemployment + tanf + child_support + veterans_benefits + workers_compensation",
                    "notes": "Not in source CSV - computed from member income fields"
                },
                "total_income": {
                    "type": "DECIMAL(10,2)",
                    "description": "Total income (earned + unearned) (calculated field)",
                    "nullable": true,
                    "source_field": "Calculated: total_earned_income + total_unearned_income",
                    "notes": "Not in source CSV - computed field"
                }
            }
        },
        "qc_errors": {
            "description": "Quality Control errors (variances) found during review. Up to 9 errors per household.",
            "row_count": "~20,000 errors across all households",
            "primary_key": "(case_id, fiscal_year, error_number)",
            "foreign_keys": [
                "(case_id, fiscal_year) → households(case_id, fiscal_year)"
            ],
            "unique_constraint": "(case_id, fiscal_year, error_number)",
            "source_notes": "Error data extracted from columns with suffix 1-9 in source CSV",
            "columns": {
                "case_id": {
                    "type": "VARCHAR(50)",
                    "description": "SNAP household identification number (part of composite primary key)",
                    "nullable": false,
                    "source_field": "HHLDNO",
                    "notes": "Part of composite primary key and foreign key to households"
                },
                "fiscal_year": {
                    "type": "INTEGER",
                    "description": "Fiscal year (part of composite primary key)",
                    "nullable": false,
                    "source_field": "Derived from data file",
                    "notes": "Part of composite primary key and foreign key to households"
                },
                "error_number": {
                    "type": "INTEGER",
                    "description": "Error sequence number for this household (1-9, part of composite primary key)",
                    "nullable": false,
                    "range": "1-9",
                    "example": 1,
                    "source_field": "Derived from column suffix (ELEMENT1→1, ELEMENT2→2, etc.)",
                    "notes": "Extracted from the 'i' in source field names like ELEMENTi, NATUREi"
                },
                "element_code": {
                    "type": "INTEGER",
                    "description": "Variance element - type of problem area",
                    "nullable": true,
                    "range": "111-820",
                    "example": 520,
                    "source_field": "ELEMENTi"
                },
                "nature_code": {
                    "type": "INTEGER",
                    "description": "Nature of variance - what went wrong",
                    "nullable": true,
                    "range": "6-309",
                    "example": 75,
                    "source_field": "NATUREi"
                },
                "responsible_agency": {
                    "type": "INTEGER",
                    "description": "Agency or client responsibility",
                    "nullable": true,
                    "range": "1-99",
                    "example": 17,
                    "source_field": "AGENCYi"
                },
                "error_amount": {
                    "type": "DECIMAL(10,2)",
                    "description": "Variance dollar amount",
                    "nullable": true,
                    "range": "0-1480",
                    "example": 57.00,
                    "source_field": "AMOUNTi"
                },
                "discovery_method": {
                    "type": "INTEGER",
                    "description": "How variance was discovered",
                    "nullable": true,
                    "range": "1-9",
                    "example": 2,
                    "source_field": "DISCOVi"
                },
                "verification_status": {
                    "type": "INTEGER",
                    "description": "How variance was verified",
                    "nullable": true,
                    "range": "1-9",
                    "example": 2,
                    "source_field": "VERIFi"
                },
                "occurrence_date": {
                    "type": "INTEGER",
                    "description": "Variance occurrence date in YYYYMM format",
