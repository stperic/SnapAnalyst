{
    "database": {
        "name": "SnapAnalyst",
        "description": "SNAP Quality Control database with normalized household, member, and QC error data. Data is structured to eliminate the wide-format CSV issue (1200+ columns reduced to ~100 columns across 3 tables).",
        "version": "1.0",
        "fiscal_years_available": [
            2021,
            2022,
            2023
        ],
        "total_households": "~150,000 across all years",
        "purpose": "Enable analysis of SNAP (food stamps) quality control reviews to understand benefit accuracy, household characteristics, income sources, and program errors.",
        "data_source": "FNS SNAP Quality Control FY2023 Public Use File"
    },
    "code_lookups": {
        "case_classification_codes": {
            "description": "Case classification for error rate calculation",
            "source_field": "CASE",
            "1": "Included in error rate calculation",
            "2": "Excluded from error rate calculation—processed by SSA worker",
            "3": "Excluded from error rate calculation, as designated by FNS (for example, demonstration project, simplified SNAP)"
        },
        "status_codes": {
            "description": "Status of case error findings",
            "source_field": "STATUS",
            "1": "Amount correct",
            "2": "Overissuance",
            "3": "Underissuance"
        },
        "expedited_service_codes": {
            "description": "Whether household received expedited SNAP benefits",
            "source_field": "EXPEDSER",
            "1": "Entitled to expedited service and received benefits within Federal time frame",
            "2": "Entitled to expedited service but did not receive benefits within Federal time frame",
            "3": "Not entitled to expedited service"
        },
        "categorical_eligibility_codes": {
            "description": "Indicator of categorical eligibility status",
            "source_field": "CAT_ELIG",
            "0": "Unit not categorically eligible for benefits",
            "1": "Unit reported as categorically eligible for benefits and therefore not subject to SNAP income or asset tests",
            "2": "Unit recoded as categorically eligible after being identified as pure cash PA or as meeting State-specified criteria for BBCE"
        },
        "error_finding_codes": {
            "description": "Impact of variance on benefits (error finding)",
            "source_field": "E_FINDG",
            "2": "Overissuance",
            "3": "Underissuance",
            "4": "Ineligible"
        },
        "sex_codes": {
            "description": "Sex of household member",
            "source_field": "SEX",
            "1": "Male",
            "2": "Female",
            "3": "Prefer not to answer"
        },
        "snap_affiliation_codes": {
            "description": "SNAP case affiliation status",
            "source_field": "FSAFIL",
            "1": "Eligible member of SNAP case under review and entitled to receive benefits",
            "2": "Eligible SNAP participant in another unit, not currently under review",
            "4": "Member is ineligible noncitizen and not participating in State-funded SNAP",
            "5": "Member not paying/cooperating with child support agency",
            "6": "Member is ineligible striker",
            "7": "Member is ineligible student",
            "8": "Member disqualified for program violation",
            "9": "Member ineligible to participate due to disqualification or failure to meet work requirements",
            "10": "ABAWD time limit exhausted",
            "11": "Fleeing felon or parole and probation violator",
            "13": "Convicted drug felon",
            "14": "Social Security Number disqualified",
            "15": "SSI recipient in California",
            "16": "Prisoner in detention center",
            "17": "Foster care",
            "18": "Member is ineligible noncitizen and participating in State-funded SNAP",
            "19": "Individual in the home but not part of SNAP household",
            "99": "Unknown"
        },
        "element_codes": {
            "description": "Type of variance element (what area had the problem)",
            "source_field": "ELEMENT",
            "111": "Student status",
            "130": "Citizenship and noncitizen status",
            "140": "Residency",
            "150": "Unit composition",
            "151": "Recipient disqualification",
            "160": "Employment and training programs",
            "161": "Time-limited participation",
            "162": "Work registration requirements",
            "163": "Voluntary quit/reduced work effort",
            "164": "Workfare and comparable workfare",
            "165": "Employment status/job availability",
            "166": "Acceptance of employment",
            "170": "Social Security number",
            "211": "Bank accounts or cash on hand",
            "212": "Nonrecurring lump-sum payment",
            "213": "Other liquid assets",
            "221": "Real property",
            "222": "Vehicles",
            "224": "Other nonliquid resources",
            "225": "Combined resources",
            "311": "Wages and salaries",
            "312": "Self-employment",
            "314": "Other earned income",
            "321": "Earned income deductions",
            "323": "Dependent care deduction",
            "331": "RSDI benefits",
            "332": "Veterans' benefits",
            "333": "SSI and/or State SSI supplement",
            "334": "Unemployment compensation",
            "335": "Workers' compensation",
            "336": "Other government benefits",
            "342": "Contributions",
            "343": "Deemed income",
            "344": "TANF, PA, or GA",
            "345": "Educational grants/scholarships/loans",
            "346": "Other unearned income",
            "350": "Child support payments received from absent parent",
            "361": "Standard deduction",
            "363": "Shelter deduction",
            "364": "Standard utility allowance",
            "365": "Medical expense deductions",
            "366": "Child support payment deduction",
            "371": "Combined gross income",
            "372": "Combined net income",
            "520": "Arithmetic computation",
            "530": "Transitional benefits",
            "560": "Reporting systems",
            "810": "SNAP simplification project",
            "820": "Demonstration projects"
        },
        "nature_codes": {
            "description": "Nature of each variance (what went wrong)",
            "source_field": "NATURE",
            "6": "Eligible person(s) excluded",
            "7": "Ineligible person(s) included",
            "12": "Eligible person(s) with no income, resources, or deductible expenses excluded",
            "13": "Eligible person(s) with income excluded",
            "14": "Eligible person(s) with resources excluded",
            "15": "Eligible person(s) with deductible expenses excluded",
            "16": "Newborn improperly excluded",
            "20": "Incorrect resource limit applied",
            "24": "Resource should have been excluded",
            "28": "Incorrect income limit applied",
            "29": "Exceeds prescribed limit",
            "30": "Resource should have been included",
            "32": "Failed to consider or incorrectly considered income of ineligible member",
            "35": "Unreported source of income (do not use for change in employment status)",
            "36": "Rounding used/not used or incorrectly applied",
            "37": "All income from source known but not included",
            "38": "More income received from this source than budgeted",
            "39": "Employment status changed from unemployed to employed",
            "40": "Employment status changed from employed to unemployed",
            "41": "Change only in amount of earnings",
            "42": "Conversion to monthly amount not used or incorrectly applied",
            "43": "Averaging not used or incorrectly applied",
            "44": "Less income received from this source than budgeted",
            "45": "Cost of doing business not used or incorrectly applied",
            "46": "Failed to consider/anticipate month with extra pay date",
            "52": "Deduction that should have been included was not",
            "53": "Deduction included that should not have been",
            "54": "Incorrect standard used (not as a result of change in unit size or move)",
            "64": "Incorrect amount used resulting from change in residence",
            "65": "Incorrect standard used resulting from change in unit size",
            "75": "Benefit/allotment/eligibility incorrectly computed",
            "77": "Unit not entitled to transitional benefits",
            "79": "Incorrect use of allotment tables",
            "80": "Improper prorating of initial month's benefits",
            "97": "Not required to be reported or acted upon based on time frames and reporting requirements",
            "98": "Transcription or computation errors",
            "99": "Other",
            "111": "Child support payment(s) not considered or incorrectly applied for initial month(s) of eligibility",
            "112": "Retained child support payment(s) not considered or incorrectly applied",
            "120": "Variance/errors resulting from noncompliance with this means-tested public assistance program",
            "123": "Incorrectly prorated",
            "124": "Variances resulting from use of automatic Federal information exchange system",
            "127": "Pass-through not considered or incorrectly applied",
            "200": "Eligible noncitizen excluded",
            "201": "Ineligible noncitizen included",
            "301": "Unit improperly participating under retrospective budgeting",
            "302": "Unit improperly participating under prospective budgeting",
            "303": "Unit improperly participating under monthly reporting",
            "304": "Unit improperly participating under quarterly reporting",
            "305": "Unit improperly participating under semiannual reporting",
            "306": "Unit improperly participating under change reporting",
            "307": "Unit improperly participating under status reporting",
            "308": "Unit improperly participating under 5 hour reporting",
            "309": "Unit improperly participating in transitional benefits"
        },
        "agency_responsibility_codes": {
            "description": "Primary cause of variance (agency vs client responsibility)",
            "source_field": "AGENCY",
            "1": "Information not reported",
            "2": "Incomplete or incorrect information provided; agency not required to verify",
            "3": "Information withheld by client (case referred for IPV investigation)",
            "4": "Incorrect information provided by client (case referred for IPV investigation)",
            "7": "Inaccurate information reported by collateral contact",
            "8": "Acted on incorrect Federal computer match information not requiring verification",
            "10": "Policy incorrectly applied",
            "12": "Reported information disregarded or not applied",
            "14": "Agency failed to follow up on inconsistent or incomplete information",
            "15": "Agency failed to follow up on impending changes",
            "16": "Agency failed to verify required information",
            "17": "Computer programming error",
            "18": "Data entry and/or coding error",
            "19": "Mass change error",
            "20": "Arithmetic computation error",
            "21": "Computer user error",
            "99": "Other"
        },
        "discovery_method_codes": {
            "description": "How variance was discovered",
            "source_field": "DISCOV",
            "1": "Variance clearly identified from case record (not automated match)",
            "2": "Variance clearly identified from case record (automated match)",
            "3": "Variance discovered from recipient interview",
            "4": "Employer (present or former)",
            "5": "Financial institution, insurance company, or other business",
            "6": "Landlord",
            "7": "Government agency or public records, not automated match",
            "8": "Government agency or public records, automated match",
            "9": "Other"
        }
    },
    "tables": {
        "households": {
            "description": "Core household case data. Each row represents one SNAP household case from quality control review.",
            "row_count": "~50,000 per fiscal year",
            "primary_key": "(case_id, fiscal_year)",
            "unique_constraint": "(case_id, fiscal_year)",
            "source_notes": "Derived from SNAP QC FY2023 Public Use File wide-format CSV with 1200+ columns",
            "columns": {
                "case_id": {
                    "type": "VARCHAR(50)",
                    "description": "SNAP household identification number (row number from source file - unique unit identifier, part of composite primary key)",
                    "nullable": false,
                    "range": "1-55115",
                    "example": "12345",
                    "source_field": "HHLDNO",
                    "notes": "Natural primary key from source data"
                },
                "fiscal_year": {
                    "type": "INTEGER",
                    "description": "Fiscal year (part of composite primary key)",
                    "nullable": false,
                    "range": "2021-2023",
                    "example": 2023,
                    "source_field": "Derived from data file name",
                    "notes": "Part of composite primary key to support multiple years"
                },
                "case_classification": {
                    "type": "INTEGER",
                    "description": "Case classification for error rate calculation",
                    "nullable": true,
                    "range": "1-3",
                    "codes": {
                        "1": "Included in error rate calculation",
                        "2": "Excluded—processed by SSA worker",
                        "3": "Excluded—designated by FNS"
                    },
                    "source_field": "CASE"
                },
                "fiscal_year": {
                    "type": "INTEGER",
                    "description": "Fiscal year of the quality control review",
                    "nullable": false,
                    "example": 2023,
                    "range": "2021-2023",
                    "source_field": "Derived from YRMONTH or specified during data load",
                    "notes": "Not explicitly in CSV - determined from year_month or load parameter"
                },
                "state_code": {
                    "type": "VARCHAR(2)",
                    "description": "FIPS code for State or territory (numeric)",
                    "nullable": true,
                    "range": "1-78",
                    "example": "9",
                    "source_field": "STATE"
                },
                "state_name": {
                    "type": "VARCHAR(50)",
                    "description": "State or territory name",
                    "nullable": true,
                    "example": "Connecticut",
                    "source_field": "STATENAME"
                },
                "year_month": {
                    "type": "VARCHAR(6)",
                    "description": "Sample year and month in YYYYMM format",
                    "nullable": true,
                    "range": "202210-202309",
                    "example": "202210",
                    "source_field": "YRMONTH"
                },
                "status": {
                    "type": "INTEGER",
                    "description": "Status of case error findings",
                    "nullable": true,
                    "range": "1-3",
                    "example": 1,
                    "source_field": "STATUS",
                    "codes": {
                        "1": "Amount correct",
                        "2": "Overissuance",
                        "3": "Underissuance"
                    }
                },
                "snap_benefit": {
                    "type": "DECIMAL(10,2)",
                    "description": "Final calculated benefit (SNAP benefit allotment)",
                    "nullable": true,
                    "range": "4-3690",
                    "example": 281.00,
                    "source_field": "FSBEN"
                },
                "raw_benefit": {
                    "type": "DECIMAL(10,2)",
                    "description": "Reported SNAP benefit received (before QC corrections)",
                    "nullable": true,
                    "range": "0-9998",
                    "example": 281.00,
                    "source_field": "RAWBEN"
                },
                "amount_error": {
                    "type": "DECIMAL(10,2)",
                    "description": "Amount of benefit in error",
                    "nullable": true,
                    "range": "0-1265",
                    "example": 0.00,
                    "source_field": "AMTERR"
                },
                "maximum_benefit": {
                    "type": "DECIMAL(10,2)",
                    "description": "Maximum benefit amount for unit size and region",
                    "nullable": true,
                    "range": "281-4092",
                    "example": 281.00,
                    "source_field": "BENMAX"
                },
                "minimum_benefit": {
                    "type": "DECIMAL(10,2)",
                    "description": "Minimum benefit amount",
                    "nullable": true,
                    "range": "23-44",
                    "example": 23.00,
                    "source_field": "MINIMUM_BEN"
                },
                "gross_income": {
                    "type": "DECIMAL(12,2)",
                    "description": "Final gross countable unit income",
                    "nullable": true,
                    "range": "0-9488",
                    "example": 561.00,
                    "source_field": "FSGRINC"
                },
                "net_income": {
                    "type": "DECIMAL(12,2)",
                    "description": "Final net countable income after deductions",
                    "nullable": true,
                    "range": "0-8499",
                    "example": 0.00,
                    "source_field": "FSNETINC"
                },
                "earned_income": {
                    "type": "DECIMAL(12,2)",
                    "description": "Countable unit earned income",
                    "nullable": true,
                    "range": "0-8365",
                    "example": 0.00,
                    "source_field": "FSEARN"
                },
                "unearned_income": {
                    "type": "DECIMAL(12,2)",
                    "description": "Countable unit unearned income",
                    "nullable": true,
                    "range": "0-6863",
                    "example": 561.00,
                    "source_field": "FSUNEARN"
                },
                "certified_household_size": {
                    "type": "INTEGER",
                    "description": "Certified unit size",
                    "nullable": true,
                    "range": "1-17",
                    "example": 1,
                    "source_field": "CERTHHSZ"
                },
                "raw_household_size": {
                    "type": "INTEGER",
                    "description": "Reported number of people in household",
                    "nullable": true,
                    "range": "1-16",
                    "example": 1,
                    "source_field": "RAWHSIZE"
                },
                "snap_unit_size": {
                    "type": "INTEGER",
                    "description": "Constructed certified unit size",
                    "nullable": true,
                    "range": "1-17",
                    "example": 1,
                    "source_field": "FSUSIZE"
                },
                "num_elderly": {
                    "type": "INTEGER",
                    "description": "Number of elderly individuals in unit (age 60+)",
                    "nullable": true,
                    "range": "0-2",
                    "example": 1,
                    "source_field": "FSNELDER"
                },
                "num_children": {
                    "type": "INTEGER",
                    "description": "Number of children in unit (under 18)",
                    "nullable": true,
                    "range": "0-15",
                    "example": 0,
                    "source_field": "FSNKID"
                },
                "num_disabled": {
                    "type": "INTEGER",
                    "description": "Number of non-elderly individuals with disabilities",
                    "nullable": true,
                    "range": "0-7",
                    "example": 0,
                    "source_field": "FSNDIS"
                },
                "num_noncitizens": {
                    "type": "INTEGER",
                    "description": "Number of noncitizens in unit",
                    "nullable": true,
                    "range": "0-10",
                    "example": 0,
                    "source_field": "FSNONCIT"
                },
                "poverty_level": {
                    "type": "DECIMAL(10,2)",
                    "description": "Gross income/poverty level ratio",
                    "nullable": true,
                    "range": "0-621",
                    "example": 50.00,
                    "source_field": "TPOV"
                },
                "categorical_eligibility": {
                    "type": "INTEGER",
                    "description": "Indicator of categorical eligibility status",
                    "nullable": true,
                    "range": "0-2",
                    "example": 1,
                    "source_field": "CAT_ELIG",
                    "codes": {
                        "0": "Unit not categorically eligible",
                        "1": "Unit categorically eligible",
                        "2": "Unit recoded as categorically eligible"
                    }
                },
                "expedited_service": {
                    "type": "INTEGER",
                    "description": "Received expedited service indicator",
                    "nullable": true,
                    "range": "1-3",
                    "example": 3,
                    "source_field": "EXPEDSER",
                    "codes": {
                        "1": "Entitled and received within Federal time frame",
                        "2": "Entitled but did NOT receive within time frame",
                        "3": "Not entitled to expedited service"
                    }
                },
                "working_poor_indicator": {
                    "type": "BOOLEAN",
                    "description": "Indicator of working poor unit",
                    "nullable": true,
                    "example": false,
                    "source_field": "WRK_POOR"
                },
                "tanf_indicator": {
                    "type": "BOOLEAN",
                    "description": "Indicator of TANF receipt for unit",
                    "nullable": true,
                    "example": false,
                    "source_field": "TANF_IND"
                },
                "standard_deduction": {
                    "type": "DECIMAL(10,2)",
                    "description": "Standard deduction",
                    "nullable": true,
                    "range": "170-515",
                    "example": 193.00,
                    "source_field": "FSSTDDED"
                },
                "earned_income_deduction": {
                    "type": "DECIMAL(10,2)",
                    "description": "Calculated earned income deduction",
                    "nullable": true,
                    "range": "0-1673",
                    "example": 0.00,
                    "source_field": "FSERNDED"
                },
                "dependent_care_deduction": {
                    "type": "DECIMAL(10,2)",
                    "description": "Reported dependent care deduction",
                    "nullable": true,
                    "range": "0-3844",
                    "example": 0.00,
                    "source_field": "FSDEPDED"
                },
                "medical_deduction": {
                    "type": "DECIMAL(10,2)",
                    "description": "Calculated medical expense deduction",
                    "nullable": true,
                    "range": "0-1978",
                    "example": 0.00,
                    "source_field": "FSMEDDED"
                },
                "shelter_deduction": {
                    "type": "DECIMAL(10,2)",
                    "description": "Calculated excess shelter expense deduction",
                    "nullable": true,
                    "range": "0-4675",
                    "example": 837.00,
                    "source_field": "FSSLTDED"
                },
                "total_deductions": {
                    "type": "DECIMAL(10,2)",
                    "description": "Total deductions",
                    "nullable": true,
                    "range": "0-7056",
                    "example": 1030.00,
                    "source_field": "FSTOTDED"
                },
                "rent": {
                    "type": "DECIMAL(10,2)",
                    "description": "Rent/mortgage amount",
                    "nullable": true,
                    "range": "0-4721",
                    "example": 100.00,
                    "source_field": "RENT"
                },
                "utilities": {
                    "type": "DECIMAL(10,2)",
                    "description": "Utility amount",
                    "nullable": true,
                    "range": "0-1075",
                    "example": 921.00,
                    "source_field": "UTIL"
                },
                "shelter_expense": {
                    "type": "DECIMAL(10,2)",
                    "description": "Calculated shelter expenses",
                    "nullable": true,
                    "range": "0-5360",
                    "example": 0.00,
                    "source_field": "FSSLTEXP"
                },
                "liquid_resources": {
                    "type": "DECIMAL(12,2)",
                    "description": "Countable liquid assets under State rules",
                    "nullable": true,
                    "range": "0-8402",
                    "example": 0.00,
                    "source_field": "LIQRESOR"
                },
                "real_property": {
                    "type": "DECIMAL(12,2)",
                    "description": "Countable real property under State rules",
                    "nullable": true,
                    "range": "0-2500",
                    "example": 0.00,
                    "source_field": "REALPROP"
                },
                "vehicle_assets": {
                    "type": "DECIMAL(12,2)",
                    "description": "Countable non-excluded vehicles' value",
                    "nullable": true,
                    "range": "0-2825",
                    "example": 0.00,
                    "source_field": "FSVEHAST"
                },
                "total_assets": {
                    "type": "DECIMAL(12,2)",
                    "description": "Total countable assets under State rules",
                    "nullable": true,
                    "range": "0-8402",
                    "example": 0.00,
                    "source_field": "FSASSET"
                },
                "certification_month": {
                    "type": "VARCHAR(6)",
                    "description": "Months in certification period",
                    "nullable": true,
                    "range": "0-95",
                    "example": "36",
                    "source_field": "CERTMTH"
                },
                "last_certification_date": {
                    "type": "INTEGER",
                    "description": "Date case was certified/recertified in YYYYMMDD format",
                    "nullable": true,
                    "range": "20130213-20230930",
                    "example": 20221015,
                    "source_field": "RCNTACTN"
                },
                "gross_test_result": {
                    "type": "INTEGER",
                    "description": "Indicator of passing gross income test",
                    "nullable": true,
                    "range": "0-1",
                    "example": 1,
                    "source_field": "FSGRTEST",
                    "codes": {
                        "0": "No",
                        "1": "Yes"
                    }
                },
                "net_test_result": {
                    "type": "INTEGER",
                    "description": "Indicator of passing net income test",
                    "nullable": true,
                    "range": "0-1",
                    "example": 1,
                    "source_field": "FSNETEST",
                    "codes": {
                        "0": "No",
                        "1": "Yes"
                    }
                },
                "household_weight": {
                    "type": "DECIMAL(18,8)",
                    "description": "Monthly sample weight",
                    "nullable": true,
                    "range": "45.99-78335.51",
                    "example": 3382.9227541,
                    "source_field": "HWGT"
                },
                "fiscal_year_weight": {
                    "type": "DECIMAL(18,8)",
                    "description": "Weight used for full-year calculations",
                    "nullable": true,
                    "range": "3.83-6527.96",
                    "example": 281.9102295,
                    "source_field": "FYWGT"
                },
                "region_code": {
                    "type": "VARCHAR(10)",
                    "description": "FNS region code",
                    "nullable": true,
                    "range": "1-7",
                    "example": "1",
                    "source_field": "REGIONCD"
                },
                "stratum": {
                    "type": "VARCHAR(20)",
                    "description": "Stratum identification",
                    "nullable": true,
                    "range": "0-0",
                    "example": "0",
                    "source_field": "STRATUM"
                },
                "composition_code": {
                    "type": "VARCHAR(10)",
                    "description": "Unit composition code",
                    "nullable": true,
                    "range": "0-5",
                    "example": "0",
                    "source_field": "COMPOSITION"
                },
                "homeless_deduction": {
                    "type": "DECIMAL(10,2)",
                    "description": "Amount of homeless household shelter deduction",
                    "nullable": true,
                    "range": "0-167",
                    "example": 0.00,
                    "source_field": "HOMELESS_DED"
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "description": "Record creation timestamp",
                    "nullable": false,
                    "source_field": "Auto-generated by database",
                    "notes": "Not in source CSV - database audit field"
                },
                "updated_at": {
                    "type": "TIMESTAMP",
                    "description": "Record last update timestamp",
                    "nullable": false,
                    "source_field": "Auto-generated by database",
                    "notes": "Not in source CSV - database audit field"
                }
            }
        },
        "household_members": {
            "description": "Individual household member data. Each household has 1-17 members.",
            "row_count": "~120,000 (about 2.4 members per household average)",
            "primary_key": "(case_id, fiscal_year, member_number)",
            "foreign_keys": [
                "(case_id, fiscal_year) → households(case_id, fiscal_year)"
            ],
            "unique_constraint": "(case_id, fiscal_year, member_number)",
            "source_notes": "Person-level data extracted from columns with suffix 1-17 in source CSV",
            "columns": {
                "case_id": {
                    "type": "VARCHAR(50)",
                    "description": "SNAP household identification number (part of composite primary key)",
                    "nullable": false,
                    "source_field": "HHLDNO",
                    "notes": "Part of composite primary key and foreign key to households"
                },
                "fiscal_year": {
                    "type": "INTEGER",
                    "description": "Fiscal year (part of composite primary key)",
